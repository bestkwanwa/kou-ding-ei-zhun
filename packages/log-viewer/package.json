{
  "name": "@kda/log-viewer",
  "version": "0.1.0",
  "description": "Web-based log viewer for kda coding agent",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kda-log": "./dist/index.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
