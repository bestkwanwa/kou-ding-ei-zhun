{
  "name": "@kda/core",
  "version": "0.1.1",
  "description": "Core agent logic, tools, LLM integration, and config for kda",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.10",
    "ai": "^6.0.185",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "effect": "^3.21.2",
    "zhipu-ai-provider": "^0.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  },
  "license": "MIT"
}
